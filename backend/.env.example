# Backend environment — copy to .env and fill in values

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=focuslens
PG_USER=postgres
PG_PASSWORD=your_password_here

# MongoDB
MONGO_URI=mongodb://localhost:27017/focuslens

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# ML Service
ML_SERVICE_URL=http://localhost:8000

# WebSocket
WS_PORT=3002